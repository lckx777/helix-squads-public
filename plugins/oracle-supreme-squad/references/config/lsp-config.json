{
  "lsp": {
    "enabled": true,
    "languages": {
      "typescript": {
        "server": "typescript-language-server",
        "rootPatterns": ["tsconfig.json", "package.json"],
        "initializationOptions": {
          "preferences": {
            "importModuleSpecifierPreference": "relative"
          }
        }
      },
      "python": {
        "server": "pylsp",
        "rootPatterns": ["setup.py", "pyproject.toml", ".git"],
        "initializationOptions": {}
      }
    },
    "capabilities": {
      "textDocument": {
        "definition": true,
        "references": true,
        "rename": true,
        "hover": true,
        "diagnostics": true,
        "codeAction": true,
        "formatting": true
      }
    },
    "connectionPoolSize": 5,
    "timeout": 30000
  }
}
